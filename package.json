{
  "name": "@duplojs/lang",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "DuploJS",
    "url": "https://github.com/duplojs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duplojs/lang.git"
  },
  "scripts": {
    "build": "./.commands/build.sh",
    "test:tu": "./.commands/test-tu.sh",
    "test:tu:watch": "./.commands/test-tu.sh --watch",
    "test:tu:update": "./.commands/test-tu.sh --update",
    "test:types": "./.commands/test-types.sh",
    "test:lint": "./.commands/test-lint.sh",
    "test:lint:fix": "./.commands/test-lint.sh --fix",
    "prepare": "husky"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./array": {
      "import": "./dist/array/index.mjs",
      "require": "./dist/array/index.cjs",
      "types": "./dist/array/index.d.ts"
    },
    "./common": {
      "import": "./dist/common/index.mjs",
      "require": "./dist/common/index.cjs",
      "types": "./dist/common/index.d.ts"
    },
    "./either": {
      "import": "./dist/either/index.mjs",
      "require": "./dist/either/index.cjs",
      "types": "./dist/either/index.d.ts"
    },
    "./object": {
      "import": "./dist/object/index.mjs",
      "require": "./dist/object/index.cjs",
      "types": "./dist/object/index.d.ts"
    },
    "./string": {
      "import": "./dist/string/index.mjs",
      "require": "./dist/string/index.cjs",
      "types": "./dist/string/index.d.ts"
    }
  },
  "devDependencies": {
    "@duplojs/code-config": "0.1.0",
    "@types/node": "24.1.0",
    "husky": "9.1.7",
    "rolldown": "1.1.5",
    "unplugin-dts": "1.0.3",
    "@typescript/typescript6": "6.0.2",
    "tslib": "2.8.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "@vitest/coverage-istanbul": "4.1.10"
  },
  "workspaces": [
    "integrations",
    "docs"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "typescript",
    "lang",
    "functional-programming",
    "immutable",
    "pipe",
    "curry",
    "data-checker",
    "either-utils",
    "array-utils",
    "object-utils",
    "string-utils",
    "duplojs"
  ],
  "engines": {
    "node": ">=24.18.0"
  }
}